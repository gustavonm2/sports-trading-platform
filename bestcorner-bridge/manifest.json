{
  "manifest_version": 3,
  "name": "BestCorner Bridge — Sports Trading",
  "version": "1.0.0",
  "description": "Extrai dados ao vivo do BestCornerStats e envia para a plataforma de trading.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bestcornerstats.com/*"
      ],
      "js": ["content-bestcorner.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "http://localhost:*/*",
        "https://*.vercel.app/*",
        "https://*.trademoreira.com.br/*",
        "https://trademoreira.com.br/*"
      ],
      "js": ["content-platform.js"],
      "run_at": "document_idle"
    }
  ]
}
